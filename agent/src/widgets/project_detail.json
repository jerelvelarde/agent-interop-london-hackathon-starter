{
  "id": "project-detail",
  "name": "ProjectDetail",
  "description": "Single-project deep-dive: status/owner cards, active sprint, milestones, kanban tasks, and open risks. Use when a PM drills into one project.",
  "catalogId": "copilotkit://app-dashboard-catalog",
  "pythonTool": "agent/src/tools/project_detail.py:show_project_detail",
  "schema": [
    { "id": "root", "component": "Column", "gap": 16, "children": ["proj-title", "header-row", "milestones-hdr", "milestones-list", "tasks-hdr", "kanban-row", "risks-hdr", "risks-column"] },
    { "id": "proj-title", "component": "Title", "text": { "path": "project.name" }, "level": "h1" },
    { "id": "header-row", "component": "Row", "gap": 16, "children": ["status-card", "owner-card", "sprint-bar"] },
    { "id": "status-card", "component": "DashboardCard", "title": "Status", "child": "status-metric" },
    { "id": "status-metric", "component": "Metric", "label": "Status", "value": { "path": "project.status" } },
    { "id": "owner-card", "component": "DashboardCard", "title": "Owner", "child": "owner-metric" },
    { "id": "owner-metric", "component": "Metric", "label": "Owner", "value": { "path": "project.ownerName" } },
    { "id": "sprint-bar", "component": "SprintTimelineBar",
      "sprintName": { "path": "sprint.name" },
      "startLabel": { "path": "sprint.startLabel" },
      "endLabel": { "path": "sprint.endLabel" },
      "percentComplete": { "path": "sprint.percentComplete" },
      "daysRemainingLabel": { "path": "sprint.daysRemainingLabel" },
      "status": { "path": "sprint.status" }
    },
    { "id": "milestones-hdr", "component": "Title", "text": "Milestones", "level": "h2" },
    { "id": "milestones-list", "component": "MilestoneList", "milestones": { "path": "project.milestones" } },
    { "id": "tasks-hdr", "component": "Title", "text": "Sprint Tasks", "level": "h2" },
    { "id": "kanban-row", "component": "Row", "gap": 12, "children": ["kc-todo", "kc-flight", "kc-review", "kc-done"] },
    { "id": "kc-todo", "component": "KanbanColumn",
      "statusLabel": "To Do",
      "count": { "path": "tasks.todoCount" },
      "children": { "componentId": "task-card", "path": "tasks.todo" }
    },
    { "id": "kc-flight", "component": "KanbanColumn",
      "statusLabel": "In Progress",
      "count": { "path": "tasks.inProgressCount" },
      "children": { "componentId": "task-card", "path": "tasks.inProgress" }
    },
    { "id": "kc-review", "component": "KanbanColumn",
      "statusLabel": "In Review",
      "count": { "path": "tasks.inReviewCount" },
      "children": { "componentId": "task-card", "path": "tasks.inReview" }
    },
    { "id": "kc-done", "component": "KanbanColumn",
      "statusLabel": "Done",
      "count": { "path": "tasks.doneCount" },
      "children": { "componentId": "task-card", "path": "tasks.done" }
    },
    { "id": "task-card", "component": "TaskCard",
      "title": { "path": "title" },
      "assigneeName": { "path": "assigneeName" },
      "assigneeInitials": { "path": "assigneeInitials" },
      "pointsLabel": { "path": "pointsLabel" },
      "dueLabel": { "path": "dueLabel" },
      "action": { "event": { "name": "open_task", "context": { "taskId": { "path": "id" } } } }
    },
    { "id": "risks-hdr", "component": "Title", "text": "Open Risks", "level": "h2" },
    { "id": "risks-column", "component": "Column", "gap": 12, "children": { "componentId": "risk-flag", "path": "risks" } },
    { "id": "risk-flag", "component": "RiskFlag",
      "severity": { "path": "severity" },
      "title": { "path": "title" },
      "ownerName": { "path": "ownerName" },
      "projectLabel": { "path": "projectLabel" },
      "mitigation": { "path": "mitigation" }
    }
  ]
}
