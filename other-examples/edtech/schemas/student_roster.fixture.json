      "trend": { "path": "trend" },
      "trendArrow": { "path": "trendArrow" },
      "riskLevel": { "path": "riskLevel" },
      "notes": { "path": "notes" },
      "drillAction": {
        "event": {
          "name": "drill_into_student",
          "context": {
            "studentId": { "path": "id" },
            "studentName": { "path": "name" }
          }
        }
      }
    }
  ],
